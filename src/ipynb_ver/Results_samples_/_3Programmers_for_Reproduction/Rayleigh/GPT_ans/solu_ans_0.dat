```python
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from itertools import product
from fractions import Fraction
from sklearn.linear_model import LinearRegression
from sklearn.metrics import r2_score
import seaborn as sns

# Fundamental dimensions: M (mass), L (length), T (time), Theta (temperature)
# Dimensional vectors for each physical quantity:
# h (height): L
# lambda (thermal conductivity): M L T^-3 Theta^-1
# delta_T (temperature difference): Theta
# g (gravity): L T^-2
# alpha (thermal expansion coefficient): Theta^-1
# nu (kinematic viscosity): L^2 T^-1
# kappa (thermal diffusivity): L^2 T^-1

# Dimensional matrix columns correspond to [h, lambda, delta_T, g, alpha, nu, kappa]
# Rows correspond to [M, L, T, Theta]
# Each entry is the exponent of the fundamental dimension in the quantity

def construct_dimensional_matrix():
    """Constructs and returns the dimensional matrix D (4x7) for the physical quantities."""
    h = [0, 1, 0, 0]       # h: L
    lam = [1, 1, -3, -1]   # lambda: M L T^-3 Theta^-1
    delta_T = [0, 0, 0, 1] # delta_T: Theta
    g = [0, 1, -2, 0]      # g: L T^-2
    alpha = [0, 0, 0, -1]  # alpha: Theta^-1
    nu = [0, 2, -1, 0]     # nu: L^2 T^-1
    kappa = [0, 2, -1, 0]  # kappa: L^2 T^-1

    D = np.array([h, lam, delta_T, g, alpha, nu, kappa]).T

    # Print dimensional matrix with labels
    quantities = ['h', 'lambda', 'delta_T', 'g', 'alpha', 'nu', 'kappa']
    dims = ['M', 'L', 'T', 'Theta']
    print("Dimensional Matrix (rows: M,L,T,Theta; columns: h,lambda,delta_T,g,alpha,nu,kappa):")
    print(pd.DataFrame(D, index=dims, columns=quantities))

    return D


def null_space(A, atol=1e-13, rtol=0):
    """Computes the null space of matrix A using SVD."""
    u, s, vh = np.linalg.svd(A)
    tol = max(atol, rtol * s[0])
    nnz = (s >= tol).sum()
    ns = vh[nnz:].conj().T
    return ns


def rational_approximation(x, max_denominator=3):
    """Approximate float x by a fraction with denominator <= max_denominator."""
    frac = Fraction(x).limit_denominator(max_denominator)
    return frac


def generate_candidate_exponents(nullspace_basis, max_abs=3, max_denominator=3):
    """
    Generate candidate exponent vectors by integer combinations of nullspace basis vectors.
    Exponents are approximated by rationals with numerator and denominator constraints.
    """
    n_vars, n_basis = nullspace_basis.shape

    if n_basis == 0:
        return []

    coeff_range = range(-3, 4)
    candidates = []
    seen = set()
    max_combinations = 10000
    count = 0

    for coeffs in product(coeff_range, repeat=n_basis):
        if all(c == 0 for c in coeffs):
            continue
        count += 1
        if count > max_combinations:
            break

        vec = np.zeros(n_vars)
        for i, c in enumerate(coeffs):
            vec += c * nullspace_basis[:, i]

        # Normalize by alpha exponent (index 4)
        alpha_exp = vec[4]
        if abs(alpha_exp) < 1e-10:
            nonzero_indices = np.where(np.abs(vec) > 1e-10)[0]
            if len(nonzero_indices) == 0:
                continue
            alpha_exp = vec[nonzero_indices[0]]
            vec_norm = vec / alpha_exp
        else:
            vec_norm = vec / alpha_exp

        vec_rat = []
        valid = True
        for x in vec_norm:
            frac = rational_approximation(x, max_denominator)
            if abs(frac.numerator) > max_abs or abs(frac.denominator) > max_denominator:
                valid = False
                break
            vec_rat.append(frac)
        if not valid:
            continue

        key = tuple((f.numerator, f.denominator) for f in vec_rat)
        if key in seen:
            continue
        seen.add(key)

        vec_float = np.array([float(f) for f in vec_rat])
        candidates.append((vec_rat, vec_float))

    return candidates


def compute_dimensionless_quantity(data, exponents):
    """Computes the dimensionless quantity as product of each physical quantity raised to its exponent."""
    vals = np.ones(len(data['h']))
    quantities = ['h', 'lambda', 'delta_T', 'g', 'alpha', 'nu', 'kappa']
    for i, q in enumerate(quantities):
        vals *= data[q] ** exponents[i]
    return vals


def fit_and_evaluate(x, y):
    """Fits linear regression y = a + b x and returns R2, slope, intercept."""
    x = x.reshape(-1, 1)
    model = LinearRegression()
    model.fit(x, y)
    y_pred = model.predict(x)
    r2 = r2_score(y, y_pred)
    return r2, model.coef_[0], model.intercept_


def plot_dimensional_matrix(D):
    plt.figure(figsize=(8, 4))
    sns.heatmap(D, annot=True, cmap='coolwarm', cbar=True,
                xticklabels=['h', 'lambda', 'delta_T', 'g', 'alpha', 'nu', 'kappa'],
                yticklabels=['M', 'L', 'T', 'Theta'])
    plt.title('Dimensional Matrix (Rows: Fundamental Dimensions, Columns: Physical Quantities)')
    plt.tight_layout()
    plt.savefig('dimensional_matrix_heatmap.png')
    plt.close()


def main():
    # Load data
    df = pd.read_csv('./dataset_rayben.csv')
    data = {q: df[q].values for q in ['h', 'lambda', 'delta_T', 'g', 'alpha', 'nu', 'kappa']}
    Nu = df['Nu'].values

    # Construct dimensional matrix
    D = construct_dimensional_matrix()
    plot_dimensional_matrix(D)

    # Compute null space
    ns = null_space(D)
    if ns.size == 0:
        print("No dimensionless groups found (null space empty).")
        return

    # Generate candidate exponent vectors
    candidates = generate_candidate_exponents(ns, max_abs=3, max_denominator=3)
    if not candidates:
        print("No valid candidate dimensionless groups found with given constraints.")
        return

    # Evaluate candidates by fitting Nu
    best_r2 = -np.inf
    best_candidate = None
    best_model_params = None

    for vec_rat, vec_float in candidates:
        dimless_vals = compute_dimensionless_quantity(data, vec_float)

        # Filter invalid values
        if np.any(dimless_vals <= 0) or np.any(np.isnan(dimless_vals)) or np.any(np.isinf(dimless_vals)):
            continue

        r2, slope, intercept = fit_and_evaluate(dimless_vals, Nu)

        if r2 > best_r2 and r2 > 0.85:
            best_r2 = r2
            best_candidate = vec_rat
            best_model_params = (slope, intercept)

    if best_candidate is None:
        print("No candidate dimensionless group achieved R2 > 0.85.")
        return

    # Print best candidate exponents
    print(f"Best dimensionless group found with R2 = {best_r2:.4f}")
    quantities = ['h', 'lambda', 'delta_T', 'g', 'alpha', 'nu', 'kappa']
    print("Exponents (normalized by alpha):")
    for q, frac in zip(quantities, best_candidate):
        print(f"  {q}: {frac.numerator}/{frac.denominator}")

    # Save regression plot
    dimless_vals = compute_dimensionless_quantity(data, np.array([float(f) for f in best_candidate]))
    plt.figure(figsize=(6, 4))
    plt.scatter(dimless_vals, Nu, label='Data', color='blue', s=20)
    x_fit = np.linspace(min(dimless_vals), max(dimless_vals), 100)
    slope, intercept = best_model_params
    y_fit = slope * x_fit + intercept
    plt.plot(x_fit, y_fit, color='red', label='Linear fit')
    plt.xlabel('Dimensionless Group Value')
    plt.ylabel('Nusselt Number (Nu)')
    plt.title(f'Nusselt Number vs Dimensionless Group (R2={best_r2:.3f})')
    plt.legend()
    plt.tight_layout()
    plt.savefig('nusselt_vs_dimensionless_group.png')
    plt.close()


if __name__ == '__main__':
    main()
```
